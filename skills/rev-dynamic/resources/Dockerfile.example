# Reverse Engineering Toolkit - Dockerfile.example
#
# Build with:
#   docker build -t re-toolkit:latest -f Dockerfile.example .
# Then record the digest:
#   docker inspect --format='{{.Id}}' re-toolkit:latest > .rev/sandbox/image-digest
#
# This image is intended to be run with strict isolation:
#   --network=none --read-only --cap-drop=ALL --security-opt=no-new-privileges
#
# Pinned base image. Bump deliberately; record new digest on rebuild.
# Platform pinned to linux/amd64 - several upstream tools (rizin static tarball,
# wasm-tools release artifacts) are only published for x86_64 Linux. On Apple
# Silicon hosts this runs under Rosetta/qemu emulation.
FROM --platform=linux/amd64 debian:12.5-slim

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH="/opt/tools/bin:/opt/ghidra/support:${PATH}"

# Base build and runtime dependencies.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        wget \
        git \
        unzip \
        xz-utils \
        build-essential \
        pkg-config \
        file \
        less \
        vim-tiny \
        openjdk-17-jdk-headless \
        python3 \
        python3-pip \
        python3-venv \
    && rm -rf /var/lib/apt/lists/*

# Static analysis - disassembler/decompiler toolchain.
# radare2 and rizin were removed from Debian repos; install from upstream
# releases pinned by version. yara remains in Debian main.
RUN apt-get update && apt-get install -y --no-install-recommends \
        binutils \
        binutils-multiarch \
        yara \
    && rm -rf /var/lib/apt/lists/*

# radare2 - upstream .deb (amd64).
RUN curl -fsSL -o /tmp/radare2.deb \
        https://github.com/radareorg/radare2/releases/download/6.1.4/radare2_6.1.4_amd64.deb && \
    echo "cef683d72f0e60b6b881b68fb1b59717f06e67c9de0ec8db761a0acb43fca474  /tmp/radare2.deb" | sha256sum -c - && \
    apt-get update && apt-get install -y --no-install-recommends /tmp/radare2.deb && \
    rm -rf /var/lib/apt/lists/* /tmp/radare2.deb

# rizin - upstream static x86_64 tarball (unpacks to bin/, lib/, include/).
RUN mkdir -p /opt/tools/bin /opt/rizin && \
    curl -fsSL -o /tmp/rizin.tar.xz \
        https://github.com/rizinorg/rizin/releases/download/v0.8.2/rizin-v0.8.2-static-x86_64.tar.xz && \
    echo "39299d492a43458900233e3036058b653d7554a6786192397fd4464c51fce5d6  /tmp/rizin.tar.xz" | sha256sum -c - && \
    tar -xJf /tmp/rizin.tar.xz -C /opt/rizin && \
    ln -s /opt/rizin/bin/rizin /opt/tools/bin/rizin && \
    rm /tmp/rizin.tar.xz

# Debugging and tracing.
RUN apt-get update && apt-get install -y --no-install-recommends \
        gdb \
        gdb-multiarch \
        lldb \
        strace \
        ltrace \
        linux-perf \
    && rm -rf /var/lib/apt/lists/*

# Emulation - qemu user and system modes, all common arches.
RUN apt-get update && apt-get install -y --no-install-recommends \
        qemu-user \
        qemu-user-static \
        qemu-system-arm \
        qemu-system-mips \
        qemu-system-x86 \
        qemu-system-misc \
    && rm -rf /var/lib/apt/lists/*

# Mobile analysis - Android + iOS tooling.
# dex2jar was removed from Debian repos; install from upstream release.
RUN apt-get update && apt-get install -y --no-install-recommends \
        apktool \
    && rm -rf /var/lib/apt/lists/*

# dex2jar - upstream release (dex-tools distribution).
RUN curl -fsSL -o /tmp/dex-tools.zip \
        https://github.com/pxb1988/dex2jar/releases/download/v2.4/dex-tools-v2.4.zip && \
    echo "ee7c45eb3c1d2474a6145d8d447e651a736a22d9664b6d3d3be5a5a817dda23a  /tmp/dex-tools.zip" | sha256sum -c - && \
    unzip -q /tmp/dex-tools.zip -d /opt && \
    mv /opt/dex-tools-v2.4 /opt/dex2jar && \
    chmod +x /opt/dex2jar/*.sh && \
    ln -s /opt/dex2jar/d2j-dex2jar.sh /opt/tools/bin/dex2jar && \
    ln -s /opt/dex2jar/d2j-dex2jar.sh /opt/tools/bin/d2j-dex2jar && \
    rm /tmp/dex-tools.zip

# Firmware extraction.
RUN apt-get update && apt-get install -y --no-install-recommends \
        binwalk \
        squashfs-tools \
        cpio \
        u-boot-tools \
    && rm -rf /var/lib/apt/lists/*

# Network/protocol analysis.
RUN apt-get update && apt-get install -y --no-install-recommends \
        tshark \
        tcpdump \
    && rm -rf /var/lib/apt/lists/*

# Python libraries for glue, scripting, and per-language RE.
# Pinned to reproducible versions; bump deliberately.
RUN pip3 install --no-cache-dir --break-system-packages \
        r2pipe==1.9.4 \
        pwntools==4.13.0 \
        lief==0.14.1 \
        capstone==5.0.1 \
        keystone-engine==0.9.2 \
        unicorn==2.0.1.post1 \
        qiling==1.4.6 \
        androguard==3.4.0a1 \
        frida==16.4.8 \
        frida-tools==12.5.0 \
        objection==1.11.0 \
        pefile==2024.8.26 \
        oletools==0.60.2 \
        flare-capa==7.3.0 \
        jefferson==0.4.5 \
        jsonschema==4.23.0 \
        kaitaistruct==0.10 \
        scapy==2.5.0

# Managed bytecode decompilers - CFR for JVM, procyon optional.
RUN mkdir -p /opt/tools/bin && \
    curl -fsSL -o /opt/tools/cfr.jar \
        https://www.benf.org/other/cfr/cfr-0.152.jar && \
    echo "f686e8f3ded377d7bc87d216a90e9e9512df4156e75b06c655a16648ae8765b2  /opt/tools/cfr.jar" | sha256sum -c - && \
    printf '#!/bin/sh\nexec java -jar /opt/tools/cfr.jar "$@"\n' > /opt/tools/bin/cfr && \
    chmod +x /opt/tools/bin/cfr

# jadx - Android decompiler.
RUN curl -fsSL -o /tmp/jadx.zip \
        https://github.com/skylot/jadx/releases/download/v1.5.0/jadx-1.5.0.zip && \
    echo "c5a713fa4800cbb9e6df85ced1bef95ba329040c95cb87d54465f108483e4ef9  /tmp/jadx.zip" | sha256sum -c - && \
    mkdir -p /opt/jadx && unzip -q /tmp/jadx.zip -d /opt/jadx && rm /tmp/jadx.zip && \
    ln -s /opt/jadx/bin/jadx /opt/tools/bin/jadx && \
    ln -s /opt/jadx/bin/jadx-gui /opt/tools/bin/jadx-gui

# Ghidra - primary decompiler. Pinned version.
RUN curl -fsSL -o /tmp/ghidra.zip \
        https://github.com/NationalSecurityAgency/ghidra/releases/download/Ghidra_11.0.3_build/ghidra_11.0.3_PUBLIC_20240410.zip && \
    echo "2462a2d0ab11e30f9e907cd3b4aa6b48dd2642f325617e3d922c28e752be6761  /tmp/ghidra.zip" | sha256sum -c - && \
    unzip -q /tmp/ghidra.zip -d /opt && \
    mv /opt/ghidra_11.0.3_PUBLIC /opt/ghidra && \
    rm /tmp/ghidra.zip

# wasm-tools and wabt for WebAssembly.
RUN curl -fsSL -o /tmp/wasm-tools.tar.gz \
        https://github.com/bytecodealliance/wasm-tools/releases/download/v1.208.1/wasm-tools-1.208.1-x86_64-linux.tar.gz && \
    echo "c49f085815f178865ae83dd00d8cb96afb46bb811c2d31f48216d90681a1b2c3  /tmp/wasm-tools.tar.gz" | sha256sum -c - && \
    tar -xzf /tmp/wasm-tools.tar.gz -C /tmp && \
    mv /tmp/wasm-tools-*/wasm-tools /opt/tools/bin/ && \
    rm -rf /tmp/wasm-tools*

RUN apt-get update && apt-get install -y --no-install-recommends \
        wabt \
    && rm -rf /var/lib/apt/lists/* && \
    printf '#!/bin/sh\n# wabt suite dispatcher: `wabt <tool> [args...]` runs the named wabt tool.\nif [ $# -eq 0 ]; then\n  echo "wabt suite (Debian package). Installed tools:" >&2\n  for t in wasm-objdump wasm2wat wat2wasm wasm-interp wasm-decompile wasm-strip wasm-validate wat-desugar wast2json; do\n    command -v "$t" >/dev/null 2>&1 && echo "  $t" >&2\n  done\n  exit 0\nfi\ncase "$1" in\n  wasm-objdump|wasm2wat|wat2wasm|wasm-interp|wasm-decompile|wasm-strip|wasm-validate|wat-desugar|wast2json) ;;\n  *) echo "wabt: unknown sub-tool '"'"'$1'"'"'" >&2; exit 2 ;;\nesac\ntool=$1; shift\nexec "$tool" "$@"\n' > /opt/tools/bin/wabt && \
    chmod +x /opt/tools/bin/wabt

# kaitai-struct-compiler for binary format parsers.
RUN curl -fsSL -o /tmp/ksc.deb \
        https://github.com/kaitai-io/kaitai_struct_compiler/releases/download/0.10/kaitai-struct-compiler_0.10_all.deb && \
    echo "2d8d9a4f72fa348bfff6f85a1b01802485bf20003f03e254ae37ffa362fdd398  /tmp/ksc.deb" | sha256sum -c - && \
    apt-get update && apt-get install -y --no-install-recommends /tmp/ksc.deb && \
    rm -rf /var/lib/apt/lists/* /tmp/ksc.deb

# Node-based JavaScript deobfuscation tooling.
RUN apt-get update && apt-get install -y --no-install-recommends \
        nodejs \
        npm \
    && rm -rf /var/lib/apt/lists/* && \
    npm install -g --silent \
        webcrack@2.14.1 \
        js-beautify@1.15.1

# Default working directory is the bind-mounted .rev/ tree.
WORKDIR /work

# Non-root user for sample execution.
RUN useradd -m -u 1000 -s /bin/bash analyst
USER analyst

# Entry is a shell; callers override with the specific analysis command.
CMD ["/bin/bash"]
