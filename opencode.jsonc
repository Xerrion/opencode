{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sonarqube": {
      // Requires: docker pull mcp/sonarqube (image must be pre-pulled)
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--read-only",
        "--tmpfs",
        "/tmp:rw,noexec,nosuid,size=64m",
        "--tmpfs",
        "/app/storage:rw,noexec,nosuid,size=64m",
        "--tmpfs",
        "/etc/ssl/certs:rw,noexec,nosuid,size=8m",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_CLOUD_URL",
        "-e",
        "SONARQUBE_IDE_PORT",
        "mcp/sonarqube",
      ],
      "environment": {
        "SONARQUBE_ORG": "{env:SONARQUBE_ORG}",
        "SONARQUBE_CLOUD_URL": "{env:SONARQUBE_CLOUD_URL}",
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_IDE_PORT": "{env:SONARQUBE_IDE_PORT}",
      },
      "enabled": true,
    },
    "servicenow": {
      // Requires: /Users/lasn/Projects/servicenow-devtools-mcp to exist (local clone)
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/Users/lasn/Projects/servicenow-devtools-mcp",
        "servicenow-devtools-mcp",
      ],
      "environment": {
        "SERVICENOW_INSTANCE_URL": "{env:SERVICENOW_MCP_DEV_INSTANCE_URL}",
        "SERVICENOW_USERNAME": "{env:SERVICENOW_MCP_USERNAME}",
        "SERVICENOW_PASSWORD": "{env:SERVICENOW_MCP_DEV_PASSWORD}",
        "MCP_TOOL_PACKAGE": "{env:SERVICENOW_MCP_TOOL_PACKAGE}",
        "SERVICENOW_ENV": "{env:SERVICENOW_MCP_DEV_ENV}",
        "SCRIPT_ALLOWED_ROOT": "/Users/lasn/Projects/ServiceNow",
      },
      "enabled": true,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 10000,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
      "timeout": 10000,
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 10000,
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      // oauth: {} triggers dynamic client registration (RFC 7591) - no explicit config needed
      "oauth": {},
      "enabled": true,
    },
  },
  "lsp": {
    "pyright": {
      "disabled": true,
    },
    "basedpyright": {
      // Requires: basedpyright-langserver in PATH (npm install -g basedpyright)
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
    },
  },
  "plugin": [
    "./plugins/sn-credential-protection.ts",
    "./plugins/sn-production-warning.ts",
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@plannotator/opencode@latest",
  ],
  "permission": {
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "glob": "allow",
    "bash": "allow",
    "task": "deny",
    "context7_*": "deny",
    "exa_*": "deny",
    "gh_grep*": "deny",
    "kagi_*": "deny", // Preemptive block - kagi MCP not configured but blocked if accidentally added
    "webfetch": "deny",
    "worktree_*": "deny",
    "wow-api-dev": "deny",
    "external_directory": {
      "/Users/lasn/.plannotator/**": "allow",
      "/Users/lasn/.local/share/wow-annotations/**": "allow",
      "/Users/lasn/Projects/**": "allow",
    },
  },
  "agent": {
    "researcher": {
      "model": "github-copilot/gpt-5.4-mini",
      "temperature": 0.3,
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "gh_grep*": "allow",
        "webfetch": "allow",
        "write": "deny",
        "edit": "deny",
        "plan_read": "deny",
        "todoread": "deny",
        "wow-api-dev": "allow",
        "read": "allow",
        "glob": "allow",
        "bash": {
          "*": "deny",
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh pr list*": "allow",
          "gh issue view*": "allow",
          "gh issue list*": "allow",
          "gh release view*": "allow",
          "gh release list*": "allow",
          "gh run view*": "allow",
          "gh run list*": "allow",
          "gh workflow list*": "allow",
          "gh search *": "allow",
          "gh api *": "allow",
          "npm view*": "allow",
          "npm info*": "allow",
          "npm show*": "allow",
          "pip show*": "allow",
          "pip index*": "allow",
          "cargo search*": "allow",
          "cargo info*": "allow",
          "man *": "allow",
          "tldr *": "allow",
          "dig *": "allow",
          "nslookup *": "allow",
          "whois *": "allow",
          "host *": "allow",
          "jq *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "wc *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "cut *": "allow",
          "awk *": "allow",
          "tr *": "allow",
        },
      },
    },
    "scribe": {
      "model": "github-copilot/gpt-5.4-mini",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "*": "deny",
        },
        "edit": "allow",
        "glob": "allow",
        "read": "allow",
        "write": "allow",
        "plan_read": "deny",
        "todoread": "deny",
      },
    },
    "coder": {
      "model": "github-copilot/claude-opus-4.6",
      "temperature": 0.3,
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "bash": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        "wow-api-dev": "allow",
      },
    },
    "reviewer": {
      "model": "github-copilot/claude-sonnet-4.6",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "rg *": "allow",
        },
        "plan_read": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow",
        "read": "allow",
        "glob": "allow",
      },
    },
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
        },
        "task": "allow",
        "worktree_create": "allow",
        "worktree_list": "allow",
        "worktree_remove": "allow",
      },
    },
    "build": {
      "prompt": "./agents/build.md",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
        },
        "task": "allow",
        "worktree_create": "allow",
        "worktree_list": "allow",
        "worktree_remove": "allow",
      },
    },
    "explore": {
      "permission": {
        "edit": "deny",
        "write": "deny",
        "plan_read": "deny",
        "todoread": "deny",
        "wow-api-dev": "allow",
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "tree *": "allow",
          "pwd": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "file *": "allow",
          "stat *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "docker inspect*": "allow",
          "docker run --rm*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git branch*": "allow",
          "git ls-files*": "allow",
          "which *": "allow",
          "realpath *": "allow",
        },
      },
    },
    "servicenow": {
      "permission": {
        "bash": { "*": "deny" },
        "edit": "deny",
        "task": "allow",
        "worktree_create": "allow",
        "worktree_list": "allow",
        "worktree_remove": "allow",
      },
    },
    "servicenow-dev": {
      "permission": {
        "bash": { "*": "deny" },
        "webfetch": "deny",
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "servicenow_*": "allow",
      },
    },
  },
  "instructions": ["./AGENTS.md", "./philosophy/AGENTS.md"],
}
