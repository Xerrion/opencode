{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sonarqube": {
      // Requires: docker pull mcp/sonarqube (image must be pre-pulled)
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--read-only",
        "--tmpfs",
        "/tmp:rw,noexec,nosuid,size=64m",
        "--tmpfs",
        "/app/storage:rw,noexec,nosuid,size=64m",
        "--tmpfs",
        "/etc/ssl/certs:rw,noexec,nosuid,size=8m",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_CLOUD_URL",
        "-e",
        "SONARQUBE_IDE_PORT",
        "mcp/sonarqube",
      ],
      "environment": {
        "SONARQUBE_ORG": "{env:SONARQUBE_ORG}",
        "SONARQUBE_CLOUD_URL": "{env:SONARQUBE_CLOUD_URL}",
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_IDE_PORT": "{env:SONARQUBE_IDE_PORT}",
      },
      "enabled": true,
    },
    "servicenow": {
      // Requires: /Users/lasn/Projects/servicenow-platform-mcp to exist (local clone)
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/Users/lasn/Projects/servicenow-platform-mcp",
        "servicenow-platform-mcp",
      ],
      "environment": {
        "SERVICENOW_INSTANCE_URL": "{env:SERVICENOW_MCP_DEV_INSTANCE_URL}",
        "SERVICENOW_USERNAME": "{env:SERVICENOW_MCP_USERNAME}",
        "SERVICENOW_PASSWORD": "{env:SERVICENOW_MCP_DEV_PASSWORD}",
        "MCP_TOOL_PACKAGE": "{env:SERVICENOW_MCP_TOOL_PACKAGE}",
        "SERVICENOW_ENV": "{env:SERVICENOW_MCP_DEV_ENV}",
        "SCRIPT_ALLOWED_ROOT": "/Users/lasn/Projects/servicenow-development/",
      },
      "enabled": true,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 10000,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
      "timeout": 10000,
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 10000,
    },
    "playwright": {
      // Requires: mise + node installed (mise use -g node@lts), chromium pre-installed (npx playwright install chromium)
      "type": "local",
      "command": [
        "mise",
        "exec",
        "--",
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--headless",
        "--isolated",
        "--browser=chromium",
        "--block-service-workers",
        "--image-responses=omit",
        "--output-dir=/tmp/playwright-mcp-research",
      ],
      "enabled": true,
    },
    // Fail-loud guard: aborts with a clear error if ATLASSIAN_* env vars are unset/empty (prevents silent zero-tools registration).
    "atlassian": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        ": \"${ATLASSIAN_URL_BASE:?ATLASSIAN_URL_BASE must be set}\"; : \"${ATLASSIAN_USERNAME:?ATLASSIAN_USERNAME must be set}\"; : \"${ATLASSIAN_API_TOKEN:?ATLASSIAN_API_TOKEN must be set}\"; exec uvx mcp-atlassian",
      ],
      "environment": {
        "JIRA_URL": "{env:ATLASSIAN_URL_BASE}",
        "JIRA_USERNAME": "{env:ATLASSIAN_USERNAME}",
        "JIRA_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}",
        "CONFLUENCE_URL": "{env:ATLASSIAN_URL_BASE}/wiki",
        "CONFLUENCE_USERNAME": "{env:ATLASSIAN_USERNAME}",
        "CONFLUENCE_API_TOKEN": "{env:ATLASSIAN_API_TOKEN}",
      },
      "enabled": true,
    },
  },
  "lsp": {
    "pyright": {
      "disabled": true,
    },
    "basedpyright": {
      // Requires: basedpyright-langserver in PATH (npm install -g basedpyright)
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
    },
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@plannotator/opencode@latest",
  ],

  // ---------------------------------------------------------------------------
  // Global permissions
  //
  // Philosophy: allow read-only / inspection operations outright, prompt ("ask")
  // for light side-effects (write, edit, webfetch), hard-deny destructive ops
  // and external MCP tools. Agents override upward as needed.
  // ---------------------------------------------------------------------------
  "permission": {
    // Filesystem — reading & globbing are always safe
    "read": "allow",
    "glob": "allow",

    // Writing/editing
    "write": "deny",
    "edit": "deny",

    // Bash — deny by default, allow only read-only / inspection tools globally.
    // Agents that need build tools, package managers, or mutating commands opt-in.
    "bash": {
      // --- File inspection (read-only) ---
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "ls *": "allow",
      "tree *": "allow",
      "find *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "realpath *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "man *": "allow",
      "tldr *": "allow",

      // --- Search & text processing ---
      "rg *": "allow",
      "grep *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "diff *": "allow",
      "jq *": "allow",

      // --- Git (read-only) ---
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git fetch*": "allow",

      // --- Networking (read-only lookups) ---
      "dig *": "allow",
      "nslookup *": "allow",
      "whois *": "allow",
      "host *": "allow",

      // --- Hard deny: destructive / dangerous ---
      "rm *": "deny",
      "sudo *": "deny",
      "shutdown*": "deny",
      "reboot*": "deny",
    },

    // Orchestration & networking
    "task": "deny",
    "webfetch": "deny",
    "worktree_*": "deny",

    // Delegate — denied by default. Only read-only sub-agents may use delegate.
    // Write-capable agents (write/edit/bash allow) must use the native task tool
    // because background delegations run outside OpenCode's session tree and the
    // undo/branching system cannot track changes made in those sessions.
    "delegate": "deny",

    // MCP tools — denied globally; agents opt-in
    // (These hit external services with real side-effects)
    "context7_*": "deny",
    "exa_*": "deny",
    "gh_grep*": "deny",
    "atlassian*": "deny",
    "sonarqube_*": "deny",
    "servicenow_*": "deny",
    "playwright_*": "deny",
    "wow-api-dev": "deny",
    "wow-api-lookup": "deny",
    "wow-wiki-fetch": "deny",
    "wow-event-info": "deny",
    "wow-blizzard-source": "deny",
    "wow-addon-lint": "deny",

    "external_directory": {
      "/Users/lasn/.plannotator/**": "allow",
      "/Users/lasn/.local/share/wow-annotations/**": "allow",
      "/Users/lasn/Projects/**": "allow",
      "/tmp/**": "allow",
      // Wow addon development directories (read-only access to API references, annotations, and FrameXML source)
      "/home/xerrion/.local/share/wow-annotations/**": "allow",
      "/home/xerrion/.local/share/wow-framexml/**": "allow",
    },
  },

  // ---------------------------------------------------------------------------
  // Agents — only override what differs from the global baseline
  // ---------------------------------------------------------------------------
  "agent": {
    // Research agent: read-only, external search tools enabled
    "researcher": {
      "model": "github-copilot/claude-opus-4.7",
      "temperature": 0.3,
      "permission": {
        // No file mutation
        "write": "deny",
        "edit": "deny",
        "delegate": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        // Enable research MCP tools
        "context7_*": "allow",
        "exa_*": "allow",
        "gh_grep*": "allow",
        "playwright_*": "allow",
        "webfetch": "allow",
        // Bash: inherits global read-only tools, add GitHub CLI read ops
        "bash": {
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh pr list*": "allow",
          "gh issue view*": "allow",
          "gh issue list*": "allow",
          "gh release view*": "allow",
          "gh release list*": "allow",
          "gh run view*": "allow",
          "gh run list*": "allow",
          "gh workflow list*": "allow",
          "gh search *": "allow",
          "gh api *": "allow",
          "npm view*": "allow",
          "npm info*": "allow",
          "npm show*": "allow",
          "pip show*": "allow",
          "pip index*": "allow",
          "cargo search*": "allow",
          "cargo info*": "allow",
        },
      },
    },

    // Documentation / prose writer
    "scribe": {
      "model": "github-copilot/gemini-3-flash-preview",
      "temperature": 0.3,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        // No bash at all
        "bash": { "*": "deny" },
      },
    },

    // Full-featured coding agent
    "coder": {
      "model": "github-copilot/claude-opus-4.7",
      "temperature": 0.3,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        "playwright_*": "allow",
        // Bash: give the coder full access to bash.
        // Reasoning for this is that the coder should not be stopped by missing permissions
        "bash": {
          "*": "allow",
          "git *": "deny",
        },
      },
    },

    // Test authoring and suite execution
    "tester": {
      "model": "github-copilot/claude-opus-4.7",
      "temperature": 0.2,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        // Bash: inherits global read-only tools, add test runners & dev tooling
        "bash": {
          // Package managers & runtimes (needed to invoke test runners)
          "bun *": "allow",
          "npm *": "allow",
          "npx *": "allow",
          "yarn *": "allow",
          "pnpm *": "allow",
          "node *": "allow",
          "deno *": "allow",
          "python *": "allow",
          "python3 *": "allow",
          "pip *": "allow",
          "pip3 *": "allow",
          "uv *": "allow",
          "cargo *": "allow",
          "go *": "allow",
          "make *": "allow",
          "dotnet *": "allow",
          // Test frameworks
          "pytest *": "allow",
          "jest *": "allow",
          "vitest *": "allow",
          "mocha *": "allow",
          // Linters / type checkers (useful alongside tests)
          "eslint *": "allow",
          "prettier *": "allow",
          "biome *": "allow",
          "tsc *": "allow",
          "pyright *": "allow",
          "basedpyright *": "allow",
          "ruff *": "allow",
          "mypy *": "allow",
          "luacheck *": "allow",
          // Shell utilities
          "env *": "allow",
          "mkdir *": "allow",
          "cp *": "allow",
          "mv *": "allow",
          "touch *": "allow",
          "chmod *": "allow",
        },
      },
    },

    // Code reviewer & refactoring analyst (read-only)
    "reviewer": {
      "model": "github-copilot/claude-opus-4.7",
      "temperature": 0.1,
      "permission": {
        "write": "deny",
        "edit": "deny",
        "delegate": "allow",
        "plan_read": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow",

        // Bash: inherits global read-only tools (no additions needed)
      },
    },

    // Failure triage & root-cause diagnosis (read-only)
    "debugger": {
      "model": "github-copilot/claude-opus-4.7",
      "temperature": 0.1,
      "permission": {
        "write": "deny",
        "edit": "deny",
        "delegate": "allow",
        "plan_read": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow",
        // Bash: inherits global read-only tools (no additions needed)
      },
    },

    // Task orchestrator / planner
    "plan": {
      "model": "github-copilot/claude-opus-4.7",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "delegate": "allow",
        "bash": { "*": "deny" },
        "task": "allow",
        "worktree_create": "allow",
        "worktree_list": "allow",
        "worktree_remove": "allow",
      },
    },

    // Build orchestrator
    "build": {
      "model": "github-copilot/claude-opus-4.7",
      "prompt": "./agents/build.md",
      "permission": {
        "read": "deny",
        "write": "deny",
        "delegate": "allow",
        "bash": { "*": "deny" },
        "task": "allow",
        "worktree_create": "allow",
        "worktree_list": "allow",
        "worktree_remove": "allow",
      },
    },

    // Filesystem & repo explorer (read-only)
    "explore": {
      "model": "github-copilot/claude-opus-4.7",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "delegate": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        "playwright_*": "allow",
        // Bash: inherits global read-only tools, add docker inspect
        "bash": {
          "docker inspect*": "allow",
        },
      },
    },

    // WoW addon reference agent (read-only + external APIs)
    "wow-addon": {
      "model": "github-copilot/claude-opus-4.7",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "delegate": "allow",
        "bash": { "*": "deny" },
        "webfetch": "allow",
        "wow-api-lookup": "allow",
        "wow-wiki-fetch": "allow",
        "wow-event-info": "allow",
        "wow-blizzard-source": "allow",
        "wow-addon-lint": "allow",
        "task": { "*": "deny" },
      },
    },

    // Git & GitHub operations
    "git": {
      "model": "github-copilot/claude-opus-4.7",
      "prompt": "./agents/git.md",
      "permission": {
        "read": "allow",
        "write": "deny",
        "edit": "deny",
        "bash": {
          "git": "allow",
          "gh": "allow",
          "cat": "allow",
        },
      },
    },

    // ServiceNow platform API agent
    "servicenow": {
      "model": "github-copilot/claude-opus-4.7",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "delegate": "allow",
        "bash": { "*": "deny" },
        "task": "allow",
        "servicenow_*": "allow",
      },
    },

    // Jira backlog authoring agent (Atlassian MCP access)
    "jira-coach": {
      "model": "github-copilot/claude-opus-4.7",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "bash": { "*": "deny" },
        "task": "allow",
        "webfetch": "deny",
        "atlassian*": "allow",
      },
    },

    // ServiceNow development agent (file access + API)
    "servicenow-dev": {
      "model": "github-copilot/claude-opus-4.7",
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": { "*": "deny" },
        "task": "allow",
        "webfetch": "deny",
        "servicenow_*": "allow",
      },
    },
  },

  "instructions": ["./AGENTS.md", "./philosophy/AGENTS.md"],
}
