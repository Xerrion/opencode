{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sonarqube": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_CLOUD_URL",
        "-e",
        "SONARQUBE_IDE_PORT",
        "mcp/sonarqube",
      ],
      "environment": {
        "SONARQUBE_ORG": "{env:SONARQUBE_ORG}",
        "SONARQUBE_CLOUD_URL": "{env:SONARQUBE_CLOUD_URL}",
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_IDE_PORT": "{env:SONARQUBE_IDE_PORT}",
      },
    },
    "servicenow": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/Users/lasn/Projects/servicenow-devtools-mcp",
        "servicenow-devtools-mcp",
      ],
      "environment": {
        "SERVICENOW_INSTANCE_URL": "{env:SERVICENOW_MCP_DEV_INSTANCE_URL}",
        "SERVICENOW_USERNAME": "{env:SERVICENOW_MCP_USERNAME}",
        "SERVICENOW_PASSWORD": "{env:SERVICENOW_MCP_DEV_PASSWORD}",
        "MCP_TOOL_PACKAGE": "{env:SERVICENOW_MCP_TOOL_PACKAGE}",
        "SERVICENOW_ENV": "{env:SERVICENOW_MCP_DEV_ENV}",
        "SENTRY_DSN": "{env:SENTRY_DSN}",
        "SENTRY_ENVIRONMENT": "{env:SENTRY_ENVIRONMENT}",
        "OTEL_ENABLED": "{env:OTEL_ENABLED}",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "{env:OTEL_EXPORTER_OTLP_ENDPOINT}",
        "OTEL_EXPORTER_CONSOLE": "{env:OTEL_EXPORTER_CONSOLE}",
        "SCRIPT_ALLOWED_ROOT": "/Users/lasn/Projects/ServiceNow",
      },
      "enabled": true,
    },
    /*"github": {
      "type": "remote",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_MCP_TOKEN}",
      },
      "url": "https://api.githubcopilot.com/mcp/",
    },*/
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
    },
    "grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "oauth": {},
    },
  },
  "lsp": {
    "pyright": {
      "disabled": true,
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
    },
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@plannotator/opencode@latest",
  ],
  "permission": {
    "task": "deny",
    "context7_*": "deny",
    "exa_*": "allow",
    "grep*": "deny",
    "kagi_*": "deny",
    "webfetch": "deny",
    "worktree_*": "deny",
    "external_directory": {
      "/Users/lasn/.plannotator/**": "allow",
      "/Users/lasn/.local/share/wow-annotations/**": "allow",
    },
  },
  "agent": {
    "researcher": {
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "write": "deny",
        "edit": "deny",
        "plan_read": "deny",
        "todoread": "deny",
        "bash": {
          "*": "deny",
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh pr list*": "allow",
          "gh issue view*": "allow",
          "gh issue list*": "allow",
          "gh release view*": "allow",
          "gh release list*": "allow",
          "gh run view*": "allow",
          "gh run list*": "allow",
          "gh workflow list*": "allow",
          "gh search *": "allow",
          "gh api *": "allow",
          "npm view*": "allow",
          "npm info*": "allow",
          "npm show*": "allow",
          "pip show*": "allow",
          "pip index*": "allow",
          "cargo search*": "allow",
          "cargo info*": "allow",
          "man *": "allow",
          "tldr *": "allow",
          "dig *": "allow",
          "nslookup *": "allow",
          "whois *": "allow",
          "host *": "allow",
          "jq *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "base64 *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "wc *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "cut *": "allow",
          "awk *": "allow",
          "tr *": "allow",
        },
      },
    },
    "scribe": {
      "model": "github-copilot/claude-sonnet-4.6",
      "permission": {
        "bash": {
          "*": "deny",
        },
        "edit": "allow",
        "glob": "allow",
        "read": "allow",
        "write": "allow",
        "plan_read": "deny",
        "todoread": "deny",
      },
    },
    "coder": {
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "grep*": "deny",
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "plan_read": "deny",
        "todoread": "deny",
      },
    },
    "reviewer": {
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "rg *": "allow",
        },
        "plan_read": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow",
      },
    },
    "plan": {
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
        },
        "task": "allow",
        "worktree_*": "allow",
      },
    },
    "build": {
      "prompt": "You are a **build orchestrator**. You coordinate implementation through delegation - you do NOT implement directly.\\\\\\\\n\\\\\\\\n## Your Role\\\\\\\\n- Delegate implementation to `coder`\\\\\\\\n- Delegate documentation to `scribe`\\\\\\\\n- Delegate codebase analysis to `explore`\\\\\\\\n- Delegate external research to `researcher`\\\\\\\\n- Interpret results and decide next steps\\\\\\\\n\\\\\\\\n## Critical Constraint\\\\\\\\nYou CANNOT edit files or run commands directly. For ALL implementation and verification, delegate to `coder`.",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
        },
        "task": "allow",
        "worktree_*": "allow",
      },
    },
    "explore": {
      "permission": {
        "edit": "deny",
        "write": "deny",
        "plan_read": "deny",
        "todoread": "deny",
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "tree *": "allow",
          "pwd": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "file *": "allow",
          "stat *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git branch*": "allow",
          "git ls-files*": "allow",
          "uname*": "allow",
          "hostname": "allow",
          "whoami": "allow",
          "which *": "allow",
          "realpath *": "allow",
        },
      },
    },
  },
  "instructions": ["./philosophy/AGENTS.md"],
}
