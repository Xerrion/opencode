{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sonarqube": {
      // Requires: docker pull mcp/sonarqube (image must be pre-pulled)
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--read-only",
        "--tmpfs",
        "/tmp:rw,noexec,nosuid,size=64m",
        "--tmpfs",
        "/app/storage:rw,noexec,nosuid,size=64m",
        "--tmpfs",
        "/etc/ssl/certs:rw,noexec,nosuid,size=8m",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "-e",
        "SONARQUBE_CLOUD_URL",
        "-e",
        "SONARQUBE_IDE_PORT",
        "mcp/sonarqube",
      ],
      "environment": {
        "SONARQUBE_ORG": "{env:SONARQUBE_ORG}",
        "SONARQUBE_CLOUD_URL": "{env:SONARQUBE_CLOUD_URL}",
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_IDE_PORT": "{env:SONARQUBE_IDE_PORT}",
      },
      "enabled": true,
    },
    "servicenow": {
      // Requires: /Users/lasn/Projects/servicenow-devtools-mcp to exist (local clone)
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "/Users/lasn/Projects/servicenow-devtools-mcp",
        "servicenow-devtools-mcp",
      ],
      "environment": {
        "SERVICENOW_INSTANCE_URL": "{env:SERVICENOW_MCP_DEV_INSTANCE_URL}",
        "SERVICENOW_USERNAME": "{env:SERVICENOW_MCP_USERNAME}",
        "SERVICENOW_PASSWORD": "{env:SERVICENOW_MCP_DEV_PASSWORD}",
        "MCP_TOOL_PACKAGE": "{env:SERVICENOW_MCP_TOOL_PACKAGE}",
        "SERVICENOW_ENV": "{env:SERVICENOW_MCP_DEV_ENV}",
        "SCRIPT_ALLOWED_ROOT": "/Users/lasn/Projects/ServiceNow",
      },
      "enabled": true,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 10000,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
      "timeout": 10000,
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true,
      "timeout": 10000,
    },
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      // oauth: {} triggers dynamic client registration (RFC 7591) - no explicit config needed
      "oauth": {},
      "enabled": true,
    },
  },
  "lsp": {
    "pyright": {
      "disabled": true,
    },
    "basedpyright": {
      // Requires: basedpyright-langserver in PATH (npm install -g basedpyright)
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"],
    },
  },
  "plugin": [
    "./plugins/sn-credential-protection.ts",
    "./plugins/sn-production-warning.ts",
    "@tarquinen/opencode-dcp@3.0.4",
    "@franlol/opencode-md-table-formatter@latest",
    "@plannotator/opencode@latest",
  ],
  "permission": {
    "read": "allow",
    "write": "deny",
    "edit": "deny",
    "glob": "deny",
    "bash": { "*": "deny" },
    "task": "deny",
    "webfetch": "deny",
    "worktree_*": "deny",
    // MCP tools - ALL denied globally, agents opt-in
    "context7_*": "deny",
    "exa_*": "deny",
    "gh_grep*": "deny",
    "kagi_*": "deny",
    "wow-api-dev": "deny",
    "atlassian_*": "deny",
    "sonarqube_*": "deny",
    "servicenow_*": "deny",
    "wow-api-lookup": "deny",
    "wow-wiki-fetch": "deny",
    "wow-event-info": "deny",
    "wow-blizzard-source": "deny",
    "wow-addon-lint": "deny",
    "external_directory": {
      "/Users/lasn/.plannotator/**": "allow",
      "/Users/lasn/.local/share/wow-annotations/**": "allow",
      "/Users/lasn/Projects/**": "allow",
    },
  },
  "agent": {
    "researcher": {
      "model": "github-copilot/gpt-5.4-mini",
      "temperature": 0.3,
      "permission": {
        "context7_*": "allow",
        "exa_*": "allow",
        "gh_grep*": "allow",
        "webfetch": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        "read": "allow",
        "glob": "allow",
        "bash": {
          "*": "deny",
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh pr list*": "allow",
          "gh issue view*": "allow",
          "gh issue list*": "allow",
          "gh release view*": "allow",
          "gh release list*": "allow",
          "gh run view*": "allow",
          "gh run list*": "allow",
          "gh workflow list*": "allow",
          "gh search *": "allow",
          "gh api *": "allow",
          "npm view*": "allow",
          "npm info*": "allow",
          "npm show*": "allow",
          "pip show*": "allow",
          "pip index*": "allow",
          "cargo search*": "allow",
          "cargo info*": "allow",
          "man *": "allow",
          "tldr *": "allow",
          "dig *": "allow",
          "nslookup *": "allow",
          "whois *": "allow",
          "host *": "allow",
          "jq *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "wc *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "cut *": "allow",
          "awk *": "allow",
          "tr *": "allow",
        },
      },
    },
    "scribe": {
      "model": "github-copilot/gpt-5.4-mini",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "*": "deny",
        },
        "edit": "allow",
        "glob": "allow",
        "read": "allow",
        "write": "allow",
        "plan_read": "deny",
        "todoread": "deny",
      },
    },
    "coder": {
      "model": "github-copilot/claude-opus-4.6",
      "temperature": 0.3,
      "permission": {
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "plan_read": "deny",
        "todoread": "deny",
        "bash": {
          "*": "deny",
          // Package managers & build tools
          "bun *": "allow",
          "npm *": "allow",
          "npx *": "allow",
          "yarn *": "allow",
          "pnpm *": "allow",
          "node *": "allow",
          "deno *": "allow",
          "python *": "allow",
          "python3 *": "allow",
          "pip *": "allow",
          "pip3 *": "allow",
          "uv *": "allow",
          "cargo *": "allow",
          "go *": "allow",
          "make *": "allow",
          "dotnet *": "allow",
          // Linters, formatters, type checkers
          "eslint *": "allow",
          "prettier *": "allow",
          "biome *": "allow",
          "tsc *": "allow",
          "pyright *": "allow",
          "basedpyright *": "allow",
          "ruff *": "allow",
          "mypy *": "allow",
          "luacheck *": "allow",
          // File inspection (read-only)
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "ls *": "allow",
          "tree *": "allow",
          "find *": "allow",
          "file *": "allow",
          "stat *": "allow",
          "realpath *": "allow",
          // Search & text processing
          "rg *": "allow",
          "grep *": "allow",
          "sed *": "allow",
          "awk *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "cut *": "allow",
          "tr *": "allow",
          "diff *": "allow",
          "jq *": "allow",
          // Shell utilities
          "echo *": "allow",
          "printf *": "allow",
          "pwd": "allow",
          "which *": "allow",
          "env *": "allow",
          "mkdir *": "allow",
          "cp *": "allow",
          "mv *": "allow",
          "touch *": "allow",
          "chmod *": "allow",
        },
      },
    },
    "code-simplifier": {
      "temperature": 0.3,
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": {
          "*": "deny",
          // Package managers & build tools
          "bun *": "allow",
          "npm *": "allow",
          "npx *": "allow",
          "yarn *": "allow",
          "pnpm *": "allow",
          "node *": "allow",
          "cargo *": "allow",
          "go *": "allow",
          "make *": "allow",
          // Linters, formatters, type checkers
          "tsc *": "allow",
          "eslint *": "allow",
          "prettier *": "allow",
          "biome *": "allow",
          "ruff *": "allow",
          "mypy *": "allow",
          "pyright *": "allow",
          "basedpyright *": "allow",
          // File inspection & search
          "rg *": "allow",
          "diff *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "ls *": "allow",
        },
      },
    },
    "code-refactorer": {
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "plan_read": "allow",
        "delegation_read": "allow",
        "bash": {
          "*": "deny",
          "git fetch*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "rg *": "allow",
        },
      },
    },
    "reviewer": {
      "model": "github-copilot/claude-sonnet-4.6",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "rg *": "allow",
        },
        "plan_read": "allow",
        "delegation_read": "allow",
        "delegation_list": "allow",
        "read": "allow",
        "glob": "allow",
      },
    },
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
        },
        "task": "allow",
        "worktree_create": "allow",
        "worktree_list": "allow",
        "worktree_remove": "allow",
      },
    },
    "build": {
      "prompt": "./agents/build.md",
      "permission": {
        "read": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
        },
        "task": "allow",
        "worktree_create": "allow",
        "worktree_list": "allow",
        "worktree_remove": "allow",
      },
    },
    "explore": {
      "permission": {
        "edit": "deny",
        "write": "deny",
        "plan_read": "deny",
        "todoread": "deny",
        "bash": {
          "*": "deny",
          "ls *": "allow",
          "tree *": "allow",
          "pwd": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "file *": "allow",
          "stat *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "docker inspect*": "allow",
          "git status*": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git branch*": "allow",
          "git ls-files*": "allow",
          "which *": "allow",
          "realpath *": "allow",
        },
      },
    },
    "wow-addon": {
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": { "*": "deny" },
        "webfetch": "allow",
        "wow-api-lookup": "allow",
        "wow-wiki-fetch": "allow",
        "wow-event-info": "allow",
        "wow-blizzard-source": "allow",
        "wow-addon-lint": "allow",
        "task": { "*": "deny" },
      },
    },
    "git": {
      "prompt": "./agents/git.md",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git *": "allow",
          "gh *": "allow",
        },
      },
    },
    "servicenow": {
      "permission": {
        "bash": { "*": "deny" },
        "edit": "deny",
        "task": "allow",
        "servicenow_*": "allow",
      },
    },
    "servicenow-dev": {
      "permission": {
        "bash": { "*": "deny" },
        "webfetch": "deny",
        "read": "allow",
        "write": "allow",
        "edit": "allow",
        "glob": "allow",
        "servicenow_*": "allow",
      },
    },
  },
  "instructions": ["./AGENTS.md", "./philosophy/AGENTS.md"],
}
